# Azure OpenAI (Cognitive Services) — never commit real values.
# This file is loaded first from repo-root .env (all keys), then server/.env overrides.
#
# Preferred names for the API server:
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview
#
# If you only maintain the root Vite file (.env at repo root), the server also accepts:
# VITE_AZURE_OPENAI_KEY, VITE_AZURE_OPENAI_ENDPOINT, VITE_AZURE_OPENAI_DEPLOYMENT, VITE_AZURE_OPENAI_API_VERSION

# Server
PORT=3000
